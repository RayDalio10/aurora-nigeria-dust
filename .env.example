# --- Copernicus ADS (used by credentials.write_cdsapirc_from_env) ---
CDSAPI_URL=https://ads.atmosphere.copernicus.eu/api
CDSAPI_KEY=your-copernicus-key-here

# --- NASA Earthdata (current code uses INTERACTIVE login; these are optional
#     reference values only, not read by the current code) ---
EARTHDATA_USERNAME=your-earthdata-username
EARTHDATA_PASSWORD=your-earthdata-password

# --- Google Earth Engine (set EE_PROJECT in src/config.py; shown here for
#     reference, not read from the environment by the current code) ---
EE_PROJECT=your-gcp-project-id

How to use before running:
# set the two Copernicus variables in your shell/session
export CDSAPI_URL="https://ads.atmosphere.copernicus.eu/api"
export CDSAPI_KEY="your-regenerated-key"
# then run; Earthdata and Earth Engine will prompt interactively on first use
python run_case_study.py
